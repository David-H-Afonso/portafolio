{
	"name": "portafolio",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"engines": {
		"node": "^20.19.0 || >=22.12.0",
		"npm": ">=10"
	},
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"lint": "eslint .",
		"preview": "vite preview",
		"create": "node scripts/create.js",
		"security:secrets": "node scripts/security-secrets.js",
		"security:headers": "node scripts/security-headers.js",
		"security:deps": "npm audit --audit-level=moderate",
		"security:audit": "npm run security:deps",
		"security:all": "npm run lint && npm run security:secrets && npm run security:headers && npm run security:deps"
	},
	"dependencies": {
		"@reduxjs/toolkit": "^2.9.0",
		"i18next": "^26.3.1",
		"react": "^19.1.1",
		"react-dom": "^19.1.1",
		"react-i18next": "^17.0.8",
		"react-redux": "^9.2.0",
		"react-router-dom": "^7.8.2",
		"redux-persist": "^6.0.0",
		"sass-embedded": "^1.92.1",
		"vite-plugin-svgr": "^5.2.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.33.0",
		"@types/node": "^24.13.2",
		"@types/react": "^19.1.10",
		"@types/react-dom": "^19.1.7",
		"@vitejs/plugin-react": "^6.0.2",
		"eslint": "^9.33.0",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-react-refresh": "^0.5.3",
		"globals": "^17.6.0",
		"typescript": "~5.8.3",
		"typescript-eslint": "^8.61.1",
		"vite": "^8.0.16"
	}
}
